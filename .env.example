# Copy to .env and fill in. .env is git-ignored — never commit real credentials.
ODOO_URL=https://wosool.odoo.com
ODOO_DB=wosool
ODOO_LOGIN=you@example.com
ODOO_API_KEY=replace-me-do-not-commit

# Optional: bearer required on the NIL endpoints (/nil/v0.1/*). Leave blank for a trusted gateway.
NIL_BEARER=

# Optional: forward NIL EVENTs to the control-plane single-pane audit.
NIL_EVENTS_WEBHOOK=
NIL_EVENTS_SECRET=
